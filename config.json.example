{
  "communities": {
    "country1_community1": {
      "community_name": "Community Name",
      "country": "country1",
      "remotefilepath_download": "/Country1/CommunityName/"
    },
    "country2_community1": {
      "community_name": "Community Name",
      "country": "country2",
      "remotefilepath_download": "/Country2/CommunityName/"
    }
  },
  "ftp": {
    "hostname": "ftp.example.com",
    "username_ibis": "ftp_username"
  },
  "keyfiles": {
    "ftp_cred_filename_IBIS": "secrets/IBIS_ftp.ini",
    "ftp_key_file_IBIS": "secrets/IBIS_ftp.key",
    "sevenz_cred_filename": "secrets/Sevenz.ini",
    "sevenz_key_file": "secrets/Sevenz.key"
  },
  "access_table_name": "baseline",
  "excluded_tablets": [],
  "db": {
    "host": "db",
    "port": 5432,
    "name": "ibis",
    "user": "ibis_user",
    "password_secret_file": "/run/secrets/db_password"
  },
  "trial": {
    "name": "ibis",
    "dedup_key": "uniqueid",
    "dedup_strategy": "latest_snapshot",
    "country_code_map": {
      "country1": 1,
      "country2": 2
    }
  },
  "schedule": {
    "pipeline_cron": "0 2 * * *",
    "store_cron": "0 3 * * 0",
    "sms_cron":               "0 9 * * *",
    "sms_weekly_report_cron": "0 7 * * 1"
  },
  "email": {
    "smtp_host": "smtp.example.com",
    "smtp_port": 587,
    "sender": "ibis-etl@example.com",
    "smtp_username": "ibis-etl@example.com",
    "pipeline_recipients": ["pi@example.com"],
    "field_recipients": {
      "country1": ["dm-country1@example.com"],
      "country2": ["dm-country2@example.com"]
    },
    "notify_countries": ["country1", "country2"],
    "keyfiles": {
      "smtp_ini": "secrets/SMTP.ini",
      "smtp_key": "secrets/SMTP.key"
    }
  },
  "sms": {
    "messages_dir": "data/sms_messages",
    "blasta_ini":   "secrets/BLASTA.ini",
    "blasta_key":   "secrets/BLASTA.key",
    "max_retries":  3,
    "dry_run":      false
  }
}
